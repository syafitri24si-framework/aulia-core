<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- WAJIB untuk WebView -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Auliacore">

        <!-- ========================= -->
        <!-- SPLASH SCREEN (LAUNCHER) -->
        <!-- ========================= -->
        <activity
            android:name=".SplashScreenActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- ========================= -->
        <!-- LOGIN -->
        <!-- ========================= -->
        <activity
            android:name=".pertemuan3.LoginActivity"
            android:exported="false" />

        <!-- ========================= -->
        <!-- WELCOME -->
        <!-- ========================= -->
        <activity
            android:name=".pertemuan3.WelcomeActivity"
            android:exported="false" />

        <!-- ========================= -->
        <!-- WEBVIEW -->
        <!-- ========================= -->
        <activity
            android:name=".pertemuan5.WebViewActivity"
            android:exported="false" />

        <!-- ========================= -->
        <!-- TAMBAHAN (BIAR TIDAK ERROR) -->
        <!-- ========================= -->

        <!-- Pertemuan 2 -->
        <activity
            android:name=".pertemuan_2.SecondActivity"
            android:exported="false" />

        <!-- Pertemuan 4 -->
        <activity
            android:name=".pertemuan4.DailyGlowActivity"
            android:exported="false" />

        <activity
            android:name=".pertemuan4.BlueMotivationActivity"
            android:exported="false" />

    </application>

</manifest>