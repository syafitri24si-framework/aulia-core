<?xml version="1.0" encoding="utf-8"?>

<resources>
    <style name="ModernButtonSmall" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/button_primary</item>
        <item name="android:textColor">@color/button_text</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:minWidth">60dp</item>
        <item name="android:minHeight">32dp</item>
    </style>

    <style name="LogoutButtonStyle" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/button_primary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">24dp</item>
        <item name="strokeColor">@color/button_primary</item>
        <item name="strokeWidth">2dp</item>
    </style>
</resources>