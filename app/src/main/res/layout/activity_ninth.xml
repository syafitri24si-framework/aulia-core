<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_soft"
    tools:context=".Home.pertemuan9.NinthActivity">

    <!-- ==================== BACKGROUND WAVE ==================== -->
    <View
        android:id="@+id/background_header"
        android:layout_width="0dp"
        android:layout_height="160dp"
        android:background="@drawable/bg_header_wave"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ==================== TOOLBAR ==================== -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarNinth"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_back"
        app:title="Pertemuan 9"
        app:titleTextColor="@color/text_white" />

    <!-- ==================== SCROLL VIEW ==================== -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbarNinth">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingTop="24dp">

            <!-- ==================== 1. TEXTINPUTLAYOUT & MATERIALBUTTON ==================== -->

            <!-- Card untuk Form Login -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔐 Form Login"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="16dp" />

                    <!-- TextInputLayout Email -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/textInputLayoutEmail"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="Email"
                        app:endIconMode="clear_text"
                        app:helperText="Masukkan email aktif Anda"
                        app:startIconDrawable="@drawable/ic_email"
                        app:startIconTint="@color/primary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textEmailAddress"
                            android:textColor="@color/text_primary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- TextInputLayout Password -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/textInputLayoutPassword"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:hint="Password"
                        app:endIconMode="password_toggle"
                        app:helperText="Minimal 6 karakter"
                        app:startIconDrawable="@drawable/ic_lock"
                        app:startIconTint="@color/primary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:textColor="@color/text_primary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- MaterialButton Login -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLogin"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="MASUK"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/button_text"
                        app:cornerRadius="28dp"
                        app:icon="@drawable/ic_login"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        android:backgroundTint="@color/button_primary" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ==================== 2. CHIP (PAKAI LINEARLAYOUT AGAR PASTI MUNCUL) ==================== -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏷️ Filter Kategori"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:orientation="horizontal"
                android:gravity="center">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTerbaru"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:checked="true"
                    android:text="Terbaru"
                    android:textColor="@color/text_primary"
                    app:chipBackgroundColor="@color/primary_soft"
                    app:chipStrokeColor="@color/primary"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPenting"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Penting"
                    android:textColor="@color/text_primary"
                    app:chipBackgroundColor="@color/primary_soft"
                    app:chipStrokeColor="@color/primary"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBelumDibaca"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Belum Dibaca"
                    android:textColor="@color/text_primary"
                    app:chipBackgroundColor="@color/primary_soft"
                    app:chipStrokeColor="@color/primary"
                    app:chipStrokeWidth="1dp" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="20dp"
                android:background="@color/text_hint" />

            <!-- ==================== 3. GRIDLAYOUT ==================== -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="🚀 Menu Aulia Core"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary" />

            <androidx.gridlayout.widget.GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                app:columnCount="3"
                app:useDefaultMargins="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGridMenu1"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:text="Dashboard"
                    android:textSize="11sp"
                    android:textColor="@color/text_primary"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_dashboard"
                    app:iconGravity="top"
                    app:iconSize="28dp"
                    app:iconTint="@color/primary"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="1dp"
                    android:backgroundTint="@color/card_background" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGridMenu2"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:text="Pengguna"
                    android:textSize="11sp"
                    android:textColor="@color/text_primary"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_person"
                    app:iconGravity="top"
                    app:iconSize="28dp"
                    app:iconTint="@color/primary"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="1dp"
                    android:backgroundTint="@color/card_background" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGridMenu3"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:text="Layanan"
                    android:textSize="11sp"
                    android:textColor="@color/text_primary"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_surat"
                    app:iconGravity="top"
                    app:iconSize="28dp"
                    app:iconTint="@color/primary"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="1dp"
                    android:backgroundTint="@color/card_background" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGridMenu4"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:text="Informasi"
                    android:textSize="11sp"
                    android:textColor="@color/text_primary"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_info"
                    app:iconGravity="top"
                    app:iconSize="28dp"
                    app:iconTint="@color/primary"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="1dp"
                    android:backgroundTint="@color/card_background" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGridMenu5"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:text="Pengumuman"
                    android:textSize="11sp"
                    android:textColor="@color/text_primary"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_report"
                    app:iconGravity="top"
                    app:iconSize="28dp"
                    app:iconTint="@color/primary"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="1dp"
                    android:backgroundTint="@color/card_background" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGridMenu6"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:text="Laporan"
                    android:textSize="11sp"
                    android:textColor="@color/text_primary"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_report"
                    app:iconGravity="top"
                    app:iconSize="28dp"
                    app:iconTint="@color/primary"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="1dp"
                    android:backgroundTint="@color/card_background" />

            </androidx.gridlayout.widget.GridLayout>

            <!-- Footer -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_gravity="center"
                android:text="✨ Aulia Core - Pertemuan 9 ✨"
                android:textSize="11sp"
                android:textColor="@color/text_hint" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>