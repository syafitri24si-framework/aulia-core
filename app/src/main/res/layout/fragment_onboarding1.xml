<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@color/background_main">

    <!-- Background decorative circle biru lembut -->
    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_marginBottom="-120dp"
        android:background="@drawable/bg_gradient_circle_blue"
        android:alpha="0.4" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="-50dp">

        <ImageView
            android:id="@+id/ivOnboardingImage"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:src="@drawable/ic_onboarding_welcome"
            android:layout_marginBottom="24dp" />

        <!-- Badge dengan aksen biru -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✨ Layanan Mandiri"
            android:textSize="12sp"
            android:textColor="@color/primary"
            android:background="@drawable/bg_badge_blue"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selamat Datang di"
            android:textSize="24sp"
            android:textStyle="normal"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bina Desa"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Platform layanan mandiri untuk mengurus berbagai surat menyurat desa secara online. Praktis, cepat, dan terpercaya."
            android:textSize="15sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginTop="16dp" />

    </LinearLayout>

</LinearLayout>